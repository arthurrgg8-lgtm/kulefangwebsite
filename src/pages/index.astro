---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingBackground from '../components/FloatingBackground.astro';

const skillTools = [
  {
    name: 'Photoshop',
    label: 'Image Editing',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3dff7e72-2865-11f1-a9ed-0242ac110002-1ysaGUoqYdQZ4tPCO7a7e.jpg'
  },
  {
    name: 'Illustrator',
    label: 'Logo Design',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3e453101-2865-11f1-a8a3-0242ac110002-dWhfjtgUWB8khvRjyjful.jpg'
  },
  {
    name: 'Figma',
    label: 'UI Design',
    src: 'https://upload.wikimedia.org/wikipedia/commons/3/33/Figma-logo.svg'
  },
  {
    name: 'Canva',
    label: 'Social Media',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3deaa46c-2865-11f1-af81-0242ac110002-xbhzjjQBshhdxj4ChvDiw.jpg'
  },
  {
    name: 'Premiere Pro',
    label: 'Video Editing',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3dd01225-2865-11f1-bced-0242ac110002-03anGr6PmHFjpNaiuKXJu.jpg'
  },
  {
    name: 'Lightroom',
    label: 'Photo Editing',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3ddc01b4-2865-11f1-934a-0242ac110002-PsAgeMDt9pINxrRgMOhre.jpg'
  }
];

const services = [
  {
    title: 'Social Media Design',
    description:
      "Create eye-catching social media content tailored to your brand's voice. From Instagram posts to stories, I design visuals that engage and convert.",
    icon: 'https://cdn.b12.io/client_media/TYuO8o08/3deaa46c-2865-11f1-af81-0242ac110002-xbhzjjQBshhdxj4ChvDiw.jpg'
  },
  {
    title: 'Brand Identity',
    description:
      "Build a cohesive brand presence with logo design, color palettes, and brand guidelines that reflect your company's values and vision.",
    icon: 'https://cdn.b12.io/client_media/TYuO8o08/ac4e7dd7-2866-11f1-8c98-0242ac110002-K6Iuu8nzHVfm6WwGVZjrt.jpg'
  },
  {
    title: 'Logo Design',
    description:
      'Craft memorable logos that stand out. Whether minimalist or bold, I create logos that become the face of your brand.',
    icon: 'https://cdn.b12.io/client_media/TYuO8o08/3e453101-2865-11f1-a8a3-0242ac110002-dWhfjtgUWB8khvRjyjful.jpg'
  },
  {
    title: 'Posters & Print',
    description:
      'Design impactful posters and print materials that capture attention and communicate your message effectively.',
    icon: 'https://cdn.b12.io/client_media/TYuO8o08/ac558150-2866-11f1-880c-0242ac110002-cVfwxloT3nXqJ_Xg94F5A.jpg'
  }
];

const featuredDesigns = [
  {
    title: 'Kiran Chemjong',
    subtitle: 'Athlete Profile Design',
    image: '/images/kiran-chemjong.jpg',
    alt: 'Kiran Chemjong profile design',
    imageClass: 'object-contain object-center'
  },
  {
    title: 'Nepal vs Sri Lanka',
    subtitle: 'Match Poster Design',
    image: '/images/nepal-vs-sri-lanka.jpg',
    alt: 'Nepal vs Sri Lanka football poster design',
    imageClass: 'object-cover object-center scale-[1.08]'
  }
];

const quickLinks = [
  {
    name: 'Instagram',
    href: 'https://www.instagram.com/creationanup/',
    icon: 'https://cdn.simpleicons.org/instagram/ffffff',
    bg: 'from-[#f58529]/80 via-[#dd2a7b]/80 to-[#8134af]/80'
  },
  {
    name: 'Behance',
    href: 'https://www.behance.net/anupcreation8',
    icon: 'https://cdn.simpleicons.org/behance/ffffff',
    bg: 'from-[#1769ff]/80 to-[#0047ff]/80'
  },
  {
    name: 'LinkedIn',
    href: 'https://www.linkedin.com/in/anup-creation-38788625a/',
    bg: 'from-[#0a66c2]/80 to-[#004182]/80',
    iconSvg:
      '<svg viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M6.94 8.5A1.56 1.56 0 1 1 6.94 5.38a1.56 1.56 0 0 1 0 3.12ZM5.5 18.5h2.88V9.64H5.5V18.5Zm4.69 0h2.87v-4.94c0-1.3.25-2.56 1.86-2.56 1.58 0 1.6 1.48 1.6 2.65v4.85h2.88v-5.44c0-2.68-.58-4.74-3.7-4.74-1.5 0-2.5.83-2.91 1.61h-.04V9.64h-2.76c.04.73 0 8.86 0 8.86Z"/></svg>',
    iconClass: 'h-4.5 w-4.5'
  },
  {
    name: 'Facebook',
    href: 'https://www.facebook.com/anupcreation8',
    icon: 'https://cdn.simpleicons.org/facebook/ffffff',
    bg: 'from-[#1877f2]/80 to-[#0d5fd3]/80',
    iconClass: 'h-4.5 w-4.5 object-contain'
  }
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>Anup Creation – Graphic Designer Portfolio</title>
    <meta
      name="description"
      content="Professional portfolio of Anup Creation, graphic designer specializing in branding, social media design, and visual storytelling with 4+ years experience."
    />
  </head>

  <body class="text-white" style="position: relative; z-index: 10;">
    <FloatingBackground opacity={0.14} />
    <Header />

    <!-- Hero Section -->
    <section
      id="hero"
      class="relative flex min-h-[auto] items-center overflow-hidden px-3 pb-10 pt-24 sm:px-4 sm:pb-12"
    >
      <div class="absolute inset-0 opacity-100">
        <div
          class="absolute inset-0"
          style="background-image: radial-gradient(circle at 20% 20%, rgba(88, 216, 255, 0.22) 0%, transparent 32%), radial-gradient(circle at 78% 76%, rgba(103, 247, 207, 0.18) 0%, transparent 28%), radial-gradient(circle at 45% 100%, rgba(66, 124, 255, 0.18) 0%, transparent 34%);"
        ></div>
      </div>

      <div class="max-w-6xl mx-auto w-full px-2 sm:px-4 relative z-10">
        <div class="mb-5 flex flex-wrap items-center justify-center gap-3 sm:mb-6 sm:gap-4 md:justify-start">
          {quickLinks.map((link) => (
            <a
              href={link.href}
              target={link.href.startsWith('http') ? '_blank' : undefined}
              rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
              aria-label={link.name}
              class={`group flex h-9 w-11 items-center justify-center rounded-lg bg-gradient-to-br ${link.bg} shadow-[0_10px_20px_rgba(0,0,0,0.18)] transition-all duration-300 hover:-translate-y-0.5 hover:scale-105 hover:shadow-[0_14px_28px_rgba(0,0,0,0.26)] sm:h-10 sm:w-12 sm:rounded-xl`}
            >
              {link.iconSvg ? (
                <span
                  class={`${link.iconClass ?? 'h-4.5 w-4.5'} opacity-95 transition-transform duration-300 group-hover:scale-110`}
                  set:html={link.iconSvg}
                />
              ) : (
                <img
                  src={link.icon}
                  alt={link.name}
                  class={`${link.iconClass ?? 'h-4.5 w-4.5 object-contain'} opacity-95 transition-transform duration-300 group-hover:scale-110`}
                  loading="lazy"
                />
              )}
            </a>
          ))}
        </div>

        <div class="grid items-center gap-6 rounded-[1.6rem] border border-white/20 bg-white/10 px-4 py-5 shadow-[0_30px_140px_rgba(38,15,104,0.32),inset_0_1px_0_rgba(255,255,255,0.18)] backdrop-blur-[22px] sm:px-5 sm:py-6 md:grid-cols-2 md:gap-12 md:rounded-[2.25rem] md:px-10 md:py-12">
          <!-- Left Content -->
          <div class="space-y-5 animate-fade-in sm:space-y-6">
            <div>
              <h1
                class="mb-2 text-3xl leading-tight font-bold text-white sm:text-5xl md:text-7xl"
                style="background: linear-gradient(135deg, #ffffff, #f9d0ff 40%, #8cf1ff 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;"
              >
                Design That Stands Out
              </h1>
              <p class="text-lg font-semibold text-[#e9d7ff] sm:text-2xl">Graphic Designer</p>
            </div>

            <p class="text-sm text-white/68 sm:text-lg">Anup Creation – Graphic Designer</p>

            <p class="max-w-md text-sm leading-relaxed text-white/82 sm:text-base">
              With 4+ years of experience, I'm passionate about visual storytelling and creating
              compelling brand identities that resonate with audiences. Let's bring your vision to
              life.
            </p>

            <div class="flex flex-col gap-3 pt-2 sm:flex-row sm:gap-4 sm:pt-4">
              <a
                href="#gallery"
                class="rounded-xl border border-white/25 bg-white/16 px-5 py-3 text-center text-sm font-bold text-white shadow-[inset_0_1px_0_rgba(255,255,255,0.2),0_18px_35px_rgba(96,77,255,0.22)] transition-all hover:-translate-y-1 hover:bg-white/22 sm:px-8 sm:text-base"
              >
                View Work
              </a>
              <a
                href="/CV-Anup.pdf"
                download
                class="rounded-xl border border-white/18 bg-white/8 px-5 py-3 text-center text-sm font-bold text-white/95 backdrop-blur-md transition-all hover:-translate-y-1 hover:bg-white/14 sm:px-8 sm:text-base"
              >
                Download CV
              </a>
            </div>
          </div>

          <!-- Right - Profile Image -->
          <div class="relative order-first flex h-64 items-center justify-center animate-fade-in-right sm:h-80 md:order-none md:h-full">
            <div
              class="absolute inset-0 bg-gradient-to-br from-green-500/20 to-transparent rounded-3xl blur-2xl"
            ></div>
            <div
              class="relative h-56 w-44 overflow-hidden rounded-[1.6rem] border border-white/18 bg-white/10 p-2 shadow-[0_40px_110px_rgba(45,15,120,0.45)] transition-all hover:-translate-y-2 hover:rotate-1 sm:h-80 sm:w-64 sm:rounded-[2rem]"
            >
              <div class="h-full w-full overflow-hidden rounded-[1.5rem] border border-cyan-200/20">
                <img
                  src="https://cdn.b12.io/client_media/TYuO8o08/525d8dc7-2855-11f1-8e89-0242ac110002-jpg-regular_image.jpeg"
                  alt="Anup Parajuli"
                  class="w-full h-full object-cover"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- About Section -->
    <section id="about" class="px-4 py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-2 sm:px-4">
        <div class="grid gap-8 md:grid-cols-2 md:gap-12 items-center">
          <div class="scroll-animate">
            <h2 class="mb-5 text-3xl font-bold text-[#f8f4ff] sm:text-4xl md:text-5xl">Hello</h2>
            <div class="space-y-4 text-sm text-white/80 sm:text-base">
              <p>
                I'm a graphic designer with a passion for creating meaningful visual experiences.
                With a Bachelor's degree in Computer Application (BCA) and 4+ years of
                professional experience, I've honed my skills in crafting compelling brand
                identities and visual content.
              </p>
              <p>
                My journey in design has been marked by collaboration with diverse clients from
                startups to established agencies where I've learned that great design is about
                understanding the client's vision and translating it into visual excellence.
              </p>
              <p>
                I specialize in brand identity, social media design, and visual storytelling,
                always with an emphasis on creating designs that are not just beautiful, but
                strategically sound and effective.
              </p>
            </div>
          </div>

          <div
            class="rounded-[1.5rem] border border-white/10 bg-white/7 p-6 space-y-5 backdrop-blur-xl shadow-[0_20px_60px_rgba(0,0,0,0.28)] scroll-animate scroll-animate-delay-1 sm:rounded-[1.75rem] sm:p-8 sm:space-y-6"
          >
            <div class="space-y-2">
              <p class="text-sm font-bold uppercase tracking-widest text-[#cff7ff]">Experience</p>
              <p class="text-4xl font-bold text-white">4+</p>
              <p class="text-white/64">Years in Design</p>
            </div>
            <div class="h-px bg-white/10"></div>
            <div class="space-y-2">
              <p class="text-sm font-bold uppercase tracking-widest text-[#cff7ff]">Projects</p>
              <p class="text-4xl font-bold text-white">50+</p>
              <p class="text-white/64">Completed Successfully</p>
            </div>
            <div class="h-px bg-white/10"></div>
            <div class="space-y-2">
              <p class="text-sm font-bold uppercase tracking-widest text-[#cff7ff]">Clients</p>
              <p class="text-4xl font-bold text-white">20+</p>
              <p class="text-white/64">Satisfied Partners</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Featured Designs -->
    <section id="featured" class="px-4 py-16 sm:py-20">
      <div class="max-w-6xl mx-auto px-2 sm:px-4">
        <div class="mb-10 text-center sm:mb-12">
          <p class="text-sm font-bold uppercase tracking-[0.3em] text-[#cff7ff] mb-4">
            Highlighted Work
          </p>
          <h2 class="text-3xl font-bold text-[#f8f4ff] sm:text-4xl md:text-5xl">Featured Designs</h2>
          <p class="mx-auto mt-4 max-w-2xl text-sm text-white/72 sm:text-base">
            These two visuals are presented as standout pieces in the portfolio.
          </p>
        </div>

        <div class="grid gap-5 md:grid-cols-2 md:gap-8">
          {featuredDesigns.map((design, index) => (
            <div
              class={`group rounded-[1.5rem] border ${index === 0 ? 'border-red-300/30' : 'border-cyan-200/30'} bg-white/8 p-2.5 backdrop-blur-xl shadow-[0_24px_70px_rgba(0,0,0,0.3)] transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_28px_90px_rgba(0,0,0,0.34)] sm:rounded-[2rem] sm:p-3`}
            >
              <div class="aspect-[4/3] overflow-hidden rounded-[1.2rem] sm:rounded-[1.5rem]">
                <img
                  src={design.image}
                  alt={design.alt}
                  class={`h-full w-full transition-transform duration-500 group-hover:scale-[1.03] ${design.imageClass}`}
                />
              </div>
              <div class="flex flex-col items-start gap-3 px-2 pb-2 pt-5 sm:flex-row sm:items-center sm:justify-between sm:gap-4">
                <div>
                  <p class="text-lg font-bold text-[#f8f4ff] sm:text-2xl">{design.title}</p>
                  <p class="mt-1 text-[11px] uppercase tracking-[0.2em] text-white/60 sm:text-sm">
                    {design.subtitle}
                  </p>
                </div>
                <span class="rounded-full border border-white/15 bg-white/10 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.2em] text-white/80 sm:px-4 sm:py-2 sm:text-xs">
                  Featured
                </span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Portfolio Gallery Section -->
    <section id="gallery" class="py-20 px-4">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="mb-12 text-center text-4xl font-bold text-[#f8f4ff] md:text-5xl">
          Portfolio Gallery
        </h2>

        <div class="grid md:grid-cols-3 gap-6">
          <!-- Portfolio Item 1 -->
          <div class="group relative h-80 cursor-pointer scroll-animate rounded-[1.75rem] border border-white/10 bg-white/7 p-2 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.26)] transition-all duration-300 hover:-translate-y-2 hover:rotate-[-1deg] hover:border-cyan-200/30">
            <img
              src="https://cdn.b12.io/client_media/TYuO8o08/e11c701e-2851-11f1-b970-0242ac110002-umJcvtPgJHOpxA2UNPTOc.jpg"
              alt="Instagram Posts Design"
              class="w-full h-full rounded-[1.25rem] object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div
              class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6"
            >
              <div>
                <p class="text-lg font-bold text-[#f8f4ff]">Instagram Posts</p>
                <p class="text-sm text-white/72">Social Media Design</p>
              </div>
            </div>
          </div>

          <!-- Portfolio Item 2 -->
          <div
            class="group relative h-80 cursor-pointer scroll-animate scroll-animate-delay-1 rounded-[1.75rem] border border-white/10 bg-white/7 p-2 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.26)] transition-all duration-300 hover:-translate-y-2 hover:rotate-[1deg] hover:border-cyan-200/30"
          >
            <img
              src="https://cdn.b12.io/client_media/TYuO8o08/e1204b2b-2851-11f1-9426-0242ac110002-uTXTAamV8zNVeJDzKKavP.jpg"
              alt="Brand Identity"
              class="w-full h-full rounded-[1.25rem] object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div
              class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6"
            >
              <div>
                <p class="text-lg font-bold text-[#f8f4ff]">Brand Identity</p>
                <p class="text-sm text-white/72">Complete Branding System</p>
              </div>
            </div>
          </div>

          <!-- Portfolio Item 3 -->
          <div
            class="group relative h-80 cursor-pointer scroll-animate scroll-animate-delay-2 rounded-[1.75rem] border border-white/10 bg-white/7 p-2 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.26)] transition-all duration-300 hover:-translate-y-2 hover:rotate-[-1deg] hover:border-cyan-200/30"
          >
            <img
              src="https://cdn.b12.io/client_media/TYuO8o08/e0f76e7a-2851-11f1-93f7-0242ac110002-aO37nloESmwCtb36z-NRG.jpg"
              alt="AI Post"
              class="w-full h-full rounded-[1.25rem] object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div
              class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6"
            >
              <div>
                <p class="text-lg font-bold text-[#f8f4ff]">AI Designs</p>
                <p class="text-sm text-white/72">AI Post</p>
              </div>
            </div>
          </div>

          <!-- Portfolio Item 4 -->
          <div
            class="group relative h-80 cursor-pointer scroll-animate scroll-animate-delay-1 rounded-[1.75rem] border border-white/10 bg-white/7 p-2 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.26)] transition-all duration-300 hover:-translate-y-2 hover:rotate-[1deg] hover:border-cyan-200/30"
          >
            <img
              src="https://cdn.b12.io/client_media/TYuO8o08/e119e57f-2851-11f1-9ac7-0242ac110002-rhgByvFsdBcgVoT-gbW7V.jpg"
              alt="Logo Designs"
              class="w-full h-full rounded-[1.25rem] object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div
              class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6"
            >
              <div>
                <p class="text-lg font-bold text-[#f8f4ff]">Logo Design</p>
                <p class="text-sm text-white/72">Brand Logos Collection</p>
              </div>
            </div>
          </div>

          <!-- Portfolio Item 5 -->
          <div
            class="group relative h-80 cursor-pointer scroll-animate scroll-animate-delay-2 rounded-[1.75rem] border border-white/10 bg-white/7 p-2 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.26)] transition-all duration-300 hover:-translate-y-2 hover:rotate-[-1deg] hover:border-cyan-200/30"
          >
            <img
              src="https://cdn.b12.io/client_media/TYuO8o08/e146a0c9-2851-11f1-b23a-0242ac110002-qWOBZLwJhY4ahj6cZ-ZnY.jpg"
              alt="Social Media Feed"
              class="w-full h-full rounded-[1.25rem] object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div
              class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6"
            >
              <div>
                <p class="text-lg font-bold text-[#f8f4ff]">Social Media Feed</p>
                <p class="text-sm text-white/72">Cohesive Brand Presence</p>
              </div>
            </div>
          </div>

          <!-- Portfolio Item 6 -->
          <div
            class="group relative h-80 cursor-pointer scroll-animate scroll-animate-delay-3 rounded-[1.75rem] border border-white/10 bg-white/7 p-2 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.26)] transition-all duration-300 hover:-translate-y-2 hover:rotate-[1deg] hover:border-cyan-200/30"
          >
            <img
              src="https://cdn.b12.io/client_media/TYuO8o08/e127b876-2851-11f1-bd39-0242ac110002-KXP9uPv6tlrYsxSzks09m.jpg"
              alt="Poster Design"
              class="w-full h-full rounded-[1.25rem] object-cover group-hover:scale-110 transition-transform duration-500"
            />
            <div
              class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity flex items-end p-6"
            >
              <div>
                <p class="text-lg font-bold text-[#f8f4ff]">Poster Design</p>
                <p class="text-sm text-white/72">Event Promotion</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Experience Section -->
    <section id="experience" class="py-20 px-4">
      <div class="max-w-6xl mx-auto px-4">
        <h2 class="mb-12 text-center text-4xl font-bold text-[#f8f4ff] md:text-5xl">Experience</h2>

        <div class="space-y-6">
          <!-- Timeline Item 1 -->
          <div class="flex gap-6 items-start group scroll-animate">
            <div class="w-3 h-3 rounded-full bg-cyan-200 mt-2 flex-shrink-0 shadow-[0_0_16px_rgba(88,216,255,0.85)]"></div>
            <div
              class="flex-1 rounded-2xl border border-white/10 bg-white/7 p-6 backdrop-blur-xl shadow-[0_20px_50px_rgba(0,0,0,0.24)] transition-all group-hover:-translate-y-1 group-hover:border-cyan-200/30"
            >
              <div class="flex items-start justify-between mb-2">
                <div>
                  <h3 class="text-xl font-bold text-[#f8f4ff]">Freelance Work</h3>
                  <p class="text-sm text-white/62">Independent Designer</p>
                </div>
                <span class="text-sm font-bold text-[#e9d7ff]">Ongoing</span>
              </div>
              <p class="text-white/72">
                Working with diverse clients including Digital Surgenous, Bhojmandu, Grafias Tech,
                and various agencies on specialized design projects.
              </p>
            </div>
          </div>

          <!-- Timeline Item 2 -->
