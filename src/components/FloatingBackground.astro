---
// Floating background component with animated tool logos
interface Props {
  opacity?: number;
}

const { opacity = 0.08 } = Astro.props;

const logos = [
  {
    name: 'Photoshop',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3dff7e72-2865-11f1-a9ed-0242ac110002-1ysaGUoqYdQZ4tPCO7a7e.jpg',
    delay: 0,
    duration: 20,
    x: 5,
    y: 10
  },
  {
    name: 'Illustrator',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3e453101-2865-11f1-a8a3-0242ac110002-dWhfjtgUWB8khvRjyjful.jpg',
    delay: 2,
    duration: 25,
    x: 80,
    y: 15
  },
  {
    name: 'Lightroom',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3ddc01b4-2865-11f1-934a-0242ac110002-PsAgeMDt9pINxrRgMOhre.jpg',
    delay: 4,
    duration: 34,
    x: 83,
    y: 66
  },
  {
    name: 'After Effects',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3dd0fdee-2865-11f1-8204-0242ac110002-x4WVASPAg6dRZBUzHWqzL.jpg',
    delay: 3,
    duration: 24,
    x: 50,
    y: 5
  },
  {
    name: 'Canva',
    src: 'https://cdn.b12.io/client_media/TYuO8o08/3deaa46c-2865-11f1-af81-0242ac110002-xbhzjjQBshhdxj4ChvDiw.jpg',
    delay: 5,
    duration: 26,
    x: 75,
    y: 80
  }
];
---

<div class="floating-background-container" style={`--opacity: ${opacity}`}>
  <div class="glass-orb orb-a"></div>
  <div class="glass-orb orb-b"></div>
  <div class="glass-orb orb-c"></div>
  <div class="glass-orb orb-d"></div>
  <div class="mesh-wave"></div>
  {logos.map((logo) => (
    <div
      class="floating-logo"
      style={`--delay: ${logo.delay}s; --duration: ${logo.duration}s; --x: ${logo.x}%; --y: ${logo.y}%;`}
    >
      <img src={logo.src} alt={logo.name} />
    </div>
  ))}
</div>

<style>
  @keyframes float {
    0%,
    100% {
      transform: translateY(0px) translateX(0px) rotate(0deg);
      opacity: calc(var(--opacity) * 0.3);
    }
    25% {
      transform: translateY(-20px) translateX(10px) rotate(5deg);
      opacity: calc(var(--opacity) * 0.6);
    }
    50% {
      transform: translateY(-40px) translateX(-10px) rotate(-5deg);
      opacity: var(--opacity);
    }
    75% {
      transform: translateY(-20px) translateX(15px) rotate(3deg);
      opacity: calc(var(--opacity) * 0.6);
    }
  }

  .floating-background-container {
    --opacity: 0.08;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
    overflow: hidden;
  }

  .glass-orb {
    position: absolute;
    border-radius: 999px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    box-shadow:
      inset 0 1px 12px rgba(255, 255, 255, 0.14),
      0 0 80px rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(10px);
    opacity: 0.8;
  }

  .orb-a {
    top: -6%;
    left: 12%;
    width: 260px;
    height: 260px;
    background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.28), rgba(255, 121, 196, 0.16) 42%, rgba(118, 54, 255, 0.12) 70%, transparent 100%);
  }

  .orb-b {
    top: -10%;
    left: 46%;
    width: 320px;
    height: 320px;
    background: radial-gradient(circle at 40% 28%, rgba(255, 255, 255, 0.3), rgba(112, 233, 255, 0.16) 44%, rgba(88, 99, 255, 0.12) 72%, transparent 100%);
  }

  .orb-c {
    right: -6%;
    top: 18%;
    width: 180px;
    height: 180px;
    background: radial-gradient(circle at 38% 32%, rgba(255, 248, 213, 0.34), rgba(255, 155, 130, 0.18) 40%, rgba(195, 84, 255, 0.12) 72%, transparent 100%);
  }

  .orb-d {
    right: 4%;
    bottom: -8%;
    width: 260px;
    height: 260px;
    background: radial-gradient(circle at 35% 30%, rgba(255, 255, 255, 0.26), rgba(95, 214, 255, 0.14) 42%, rgba(88, 99, 255, 0.1) 72%, transparent 100%);
  }

  .orb-a,
  .orb-b,
  .orb-c,
  .orb-d {
    animation: drift 18s ease-in-out infinite;
  }

  .orb-b {
    animation-delay: 2s;
  }

  .orb-c {
    animation-delay: 4s;
  }

  .orb-d {
    animation-delay: 6s;
  }

  .mesh-wave {
    position: absolute;
    left: 14%;
    right: 10%;
    top: 34%;
    height: 38%;
    border-radius: 999px;
    background:
      radial-gradient(circle at 20% 50%, rgba(108, 224, 255, 0.42), transparent 22%),
      radial-gradient(circle at 52% 30%, rgba(185, 140, 255, 0.36), transparent 28%),
      radial-gradient(circle at 82% 60%, rgba(92, 255, 237, 0.34), transparent 20%),
      linear-gradient(180deg, rgba(114, 217, 255, 0.56), rgba(98, 140, 255, 0.46));
    filter: blur(42px);
    opacity: 0.72;
    transform: rotate(-6deg);
  }

  @keyframes drift {
    0%,
    100% {
      transform: translate3d(0, 0, 0) scale(1);
    }
    50% {
      transform: translate3d(0, 12px, 0) scale(1.03);
    }
  }

  .floating-logo {
    position: absolute;
    width: 84px;
    height: 84px;
    left: var(--x);
    top: var(--y);
    animation: float var(--duration) ease-in-out infinite;
    animation-delay: var(--delay);
    filter: blur(1.4px);
    opacity: 0.35;
  }

  .floating-logo img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    filter: opacity(calc(var(--opacity) * 0.55)) brightness(1.08) saturate(0.82);
  }

  @media (max-width: 768px) {
    .orb-a,
    .orb-b,
    .orb-d {
      width: 160px;
      height: 160px;
    }

    .orb-c {
      width: 110px;
      height: 110px;
    }

    .mesh-wave {
      left: 8%;
      right: 8%;
      top: 40%;
      height: 28%;
      filter: blur(28px);
    }

    .floating-logo {
      width: 60px;
      height: 60px;
      opacity: calc(var(--opacity) * 0.5) !important;
    }

    @keyframes float {
      0%,
      100% {
        transform: translateY(0px) translateX(0px) rotate(0deg);
      }
      50% {
        transform: translateY(-20px) translateX(-8px) rotate(-3deg);
      }
    }
  }
</style>
